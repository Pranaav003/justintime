{
  "name": "justintime",
  "displayName": "JustInTime",
  "description": "AI-guided, step-by-step code walkthroughs. Claude decomposes a problem into gated steps, navigates you to each change, explains it, and waits for your approval.",
  "version": "0.0.1",
  "publisher": "pranaaviyer",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "justintime.start",
        "title": "JustInTime: Start Walkthrough"
      },
      {
        "command": "justintime.pause",
        "title": "JustInTime: Pause"
      },
      {
        "command": "justintime.resume",
        "title": "JustInTime: Resume"
      },
      {
        "command": "justintime.skip",
        "title": "JustInTime: Skip Step"
      },
      {
        "command": "justintime.revertAll",
        "title": "JustInTime: Revert All"
      },
      {
        "command": "justintime.setApiKey",
        "title": "JustInTime: Set Anthropic API Key"
      }
    ],
    "configuration": {
      "title": "JustInTime",
      "properties": {
        "justintime.provider": {
          "type": "string",
          "enum": [
            "claude-agent-sdk"
          ],
          "default": "claude-agent-sdk",
          "description": "Model provider backend. Built for Claude; additional providers are planned."
        },
        "justintime.model": {
          "type": "string",
          "default": "",
          "description": "Claude model to use (blank = your Claude default). Set this if your API key or gateway restricts which models are available."
        },
        "justintime.diffStyle": {
          "type": "string",
          "enum": [
            "inline",
            "split"
          ],
          "default": "inline",
          "description": "Default diff display mode."
        },
        "justintime.autoNavigate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open and scroll to the target file on each step."
        },
        "justintime.showPrerequisites": {
          "type": "boolean",
          "default": true,
          "description": "Show the prerequisites section in the explanation panel."
        },
        "justintime.highlightColor": {
          "type": "string",
          "default": "#FFF3CD",
          "description": "Background color for the target code range highlight."
        },
        "justintime.secondaryHighlightColor": {
          "type": "string",
          "default": "#D1ECF1",
          "description": "Background color for related code highlights."
        },
        "justintime.maxSteps": {
          "type": "number",
          "default": 30,
          "description": "Maximum number of steps per walkthrough."
        },
        "justintime.contextLines": {
          "type": "number",
          "default": 3,
          "description": "Lines of surrounding context used to anchor a diff hunk."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:e2e": "node esbuild-e2e.mjs",
    "test:e2e": "npm run build && npm run build:e2e && node dist-e2e/runTest.js",
    "smoke": "node esbuild-smoke.mjs && node dist-smoke/smoke.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.25.12",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.205",
    "dompurify": "^3.4.11",
    "marked": "^18.0.6",
    "zod": "^4.4.3"
  }
}
